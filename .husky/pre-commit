#!/usr/bin/env sh

# Scan staged files for secrets before commit
# secretlint catches known token formats (AWS, GitHub, Slack, etc.)
# Custom grep catches hex private keys and env files with secrets

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND_SECRETS=0

# Check for hex private keys (0x + 64 hex chars)
PRIV_KEY_HITS=$(echo "$STAGED_FILES" | xargs grep -lE '0x[0-9a-fA-F]{64}' 2>/dev/null)
if [ -n "$PRIV_KEY_HITS" ]; then
  echo "🚨 BLOCKED: Possible private key found in staged files:"
  echo "$PRIV_KEY_HITS"
  echo ""
  echo "If this is intentional (e.g., contract address), use: git commit --no-verify"
  FOUND_SECRETS=1
fi

# Check for .env files with actual secret values
ENV_HITS=$(echo "$STAGED_FILES" | grep -E '\.env' | xargs grep -lE '(PRIVATE_KEY|SECRET|PASSWORD|API_KEY)=.+' 2>/dev/null)
if [ -n "$ENV_HITS" ]; then
  echo "🚨 BLOCKED: Possible secrets in env file:"
  echo "$ENV_HITS"
  echo ""
  echo "Use .env.example with placeholder values instead."
  FOUND_SECRETS=1
fi

if [ "$FOUND_SECRETS" -eq 1 ]; then
  exit 1
fi

# Run secretlint for known token formats
echo "$STAGED_FILES" | xargs npx secretlint

# Run lint-staged for code linting
npx lint-staged
